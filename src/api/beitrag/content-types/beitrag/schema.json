{
  "kind": "collectionType",
  "collectionName": "beitraege",
  "info": {
    "singularName": "beitrag",
    "pluralName": "beitraege",
    "displayName": "Blog / News",
    "description": "Blog- und News-Beiträge"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "titel": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "inhalt": {
      "type": "richtext",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "titelbild": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "kategorie": {
      "type": "enumeration",
      "enum": [
        "News",
        "Tipps & Tricks",
        "Montage",
        "Produkte"
      ],
      "default": "News",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "kurztext": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "autor": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "slug": {
      "type": "uid",
      "targetField": "titel",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}