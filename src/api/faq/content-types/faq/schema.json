{
  "kind": "collectionType",
  "collectionName": "faqs",
  "info": {
    "singularName": "faq",
    "pluralName": "faqs",
    "displayName": "FAQ",
    "description": "Häufig gestellte Fragen"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "frage": {
      "type": "string",
