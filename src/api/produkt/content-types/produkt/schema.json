{
  "kind": "collectionType",
  "collectionName": "produkte",
  "info": {
    "singularName": "produkt",
    "pluralName": "produkte",
    "displayName": "Produkt",
    "description": "Dachboxen und Zubehör"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "beschreibung": {
      "type": "richtext",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "bild": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "galerie": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images"
      ]
    },
    "kategorie": {
      "type": "enumeration",
      "enum": [
        "Dachbox",
        "Dachträger",
        "Zubehör",
        "Ersatzteile"
      ],
      "default": "Dachbox",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "verfuegbar": {
      "type": "boolean",
      "default": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "artikelnummer": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "highlights": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "rentware_snippet": {
      "type": "text",
      "required": false,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  }
}