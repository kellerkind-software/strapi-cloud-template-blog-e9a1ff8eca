{
  "kind": "collectionType",
  "collectionName": "kontaktanfragen",
  "info": {
    "singularName": "kontaktanfrage",
    "pluralName": "kontaktanfragen",
    "displayName": "Kontaktanfrage",
    "description": "Eingehende Kontaktformular-Nachrichten"
